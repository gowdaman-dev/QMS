<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <iisnode
      loggingEnabled="true"
      logDirectory="iisnode"
      devErrorsEnabled="true"
    />

    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <rule name="NextJS" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

  </system.webServer>
</configuration>
