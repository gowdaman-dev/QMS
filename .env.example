# OPTION 2: Local SQL Server (Use this for development)
# Uncomment and update these lines for local development
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=YourStrong!Password
DB_NAME=queuemanagement
DB_ENCRYPT=false
TrustServerCertificate=true
DATABASE_URL=sqlserver://localhost:1433;database=queuemanagement;user=sa;password=YourStrong!Password;encrypt=false;trustServerCertificate=true;connection_limit=10;pool_timeout=20;connect_timeout=30

# OPTION 3: LocalDB (SQL Server Express LocalDB)
# DATABASE_URL=sqlserver://localhost\\SQLEXPRESS:1433;database=queuemanagement;integratedSecurity=true;trustServerCertificate=true;connection_limit=10;pool_timeout=20;connect_timeout=30

# ===========================================
# OTHER CONFIGURATIONS
# ===========================================

# Encryption key for scripts (change in production)
ENCRYPTION_KEY=QMS-production

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# Redis (Optional - for Socket.io scaling)
REDIS_HOST=localhost
REDIS_PORT=6379

# Twilio SMS (Optional)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Resend Email (Optional)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# App
PORT=9001
NODE_ENV=development

# Microsoft OAuth (Optional)
# MICROSOFT_CLIENT_ID=your-client-id
# MICROSOFT_CLIENT_SECRET=your-client-secret
# MICROSOFT_CALLBACK_URL=http://localhost:9001/auth/microsoft/callback
