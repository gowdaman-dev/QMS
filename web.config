<configuration>
  <system.webServer>
  <httpErrors errorMode="Detailed" />
    <rewrite>
      <rules>
        <rule name="ReverseProxyInboundRule1" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:9101/{R:1}" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>